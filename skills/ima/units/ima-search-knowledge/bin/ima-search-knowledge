#!/bin/bash
set -e

input_data=$(cat)

API_SCRIPT="$(dirname "$0")/../../../ima_api.cjs"

QUERY=$(echo "$input_data" | node -e "
  const fs = require('fs');
  const input = fs.readFileSync(0, 'utf8');
  const data = JSON.parse(input);
  const q = data.params ? data.params.query : data.query;
  process.stdout.write(q != null ? String(q) : '');
")

KB_ID=$(echo "$input_data" | node -e "
  const fs = require('fs');
  const input = fs.readFileSync(0, 'utf8');
  const data = JSON.parse(input);
  const kb = data.params ? data.params.knowledge_base_id : data.knowledge_base_id;
  process.stdout.write(kb || '');
")

CURSOR=$(echo "$input_data" | node -e "
  const fs = require('fs');
  const input = fs.readFileSync(0, 'utf8');
  const data = JSON.parse(input);
  const c = data.params ? data.params.cursor : data.cursor;
  process.stdout.write(c != null ? String(c) : '');
")

LIMIT=$(echo "$input_data" | node -e "
  const fs = require('fs');
  const input = fs.readFileSync(0, 'utf8');
  const data = JSON.parse(input);
  const l = data.params ? data.params.limit : data.limit;
  process.stdout.write(l != null ? String(l) : '20');
")

BODY="{\"query\": \"$QUERY\", \"knowledge_base_id\": \"$KB_ID\", \"cursor\": \"$CURSOR\", \"limit\": $LIMIT}"

RESPONSE=$(node "$API_SCRIPT" "openapi/wiki/v1/search_knowledge" "$BODY" 2>&1)

echo "$RESPONSE" | node -e "
  const fs = require('fs');
  const data = JSON.parse(fs.readFileSync(0, 'utf8'));
  if (data.code !== 0) {
    console.error(data.msg);
    process.exit(1);
  }
  console.log(JSON.stringify({
    info_list: data.data.info_list || [],
    is_end: data.data.is_end,
    next_cursor: data.data.next_cursor || ''
  }));
"
