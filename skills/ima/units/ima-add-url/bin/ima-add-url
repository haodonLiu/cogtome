#!/bin/bash
set -e

input_data=$(cat)

# Extract params from input
KB_ID=$(echo "$input_data" | node -e "
  const fs = require('fs');
  const input = fs.readFileSync(0, 'utf8');
  const data = JSON.parse(input);
  const kb = data.params ? data.params.knowledge_base_id : data.knowledge_base_id;
  process.stdout.write(kb || '');
")

FOLDER_ID=$(echo "$input_data" | node -e "
  const fs = require('fs');
  const input = fs.readFileSync(0, 'utf8');
  const data = JSON.parse(input);
  const folder = data.params ? data.params.folder_id : data.folder_id;
  process.stdout.write(folder || '');
")

URLS=$(echo "$input_data" | node -e "
  const fs = require('fs');
  const input = fs.readFileSync(0, 'utf8');
  const data = JSON.parse(input);
  const urls = data.params ? data.params.urls : data.urls;
  if (Array.isArray(urls)) {
    const quoted = urls.map(u => '\"' + String(u).replace(/\"/g, '\\\\\"') + '\"');
    process.stdout.write('[' + quoted.join(',') + ']');
  } else {
    process.stdout.write('[]');
  }
")

if [ -z "$KB_ID" ]; then
  echo "Error: knowledge_base_id is required" >&2
  exit 1
fi

if [ "$URLS" = "[]" ]; then
  echo "Error: urls array is required" >&2
  exit 1
fi

API_SCRIPT="$(dirname "$0")/../../../ima_api.cjs"

# Build body - omit folder_id if empty (for root folder)
if [ -n "$FOLDER_ID" ]; then
  BODY="{\"knowledge_base_id\": \"$KB_ID\", \"folder_id\": \"$FOLDER_ID\", \"urls\": $URLS}"
else
  BODY="{\"knowledge_base_id\": \"$KB_ID\", \"urls\": $URLS}"
fi

RESPONSE=$(node "$API_SCRIPT" "openapi/wiki/v1/import_urls" "$BODY" 2>&1) || {
  echo "API call failed: $RESPONSE" >&2
  exit 1
}

echo "$RESPONSE" | node -e "
  const fs = require('fs');
  const data = JSON.parse(fs.readFileSync(0, 'utf8'));
  if (data.code !== 0) {
    console.error('API error: ' + data.msg);
    process.exit(1);
  }
  const results = data.data.results || {};
  const output = [];
  for (const [url, info] of Object.entries(results)) {
    output.push({ url, ret_code: info.ret_code, media_id: info.media_id });
  }
  console.log(JSON.stringify({ results: output }));
"
