#!/usr/bin/env python3
import sys, json

try:
    inp = json.load(sys.stdin)
    text = inp.get("text")
    if text is None:
        print(json.dumps({"error": "missing field: text"}), file=sys.stderr)
        sys.exit(1)
    print(json.dumps({"result": text[::-1]}))
except Exception as e:
    print(json.dumps({"error": str(e)}), file=sys.stderr)
    sys.exit(1)
