{
  "name": "midnight-reflection",
  "type": "motif",
  "version": "2.0",
  "required_units": ["memory-indexer", "task-extractor", "pattern-finder", "report-writer"],
  "graph": {
    "nodes": [
      {
        "id": "start",
        "type": "start",
        "position": { "x": 0, "y": 100 }
      },
      {
        "id": "index_memory",
        "type": "unit",
        "unit": "memory-indexer",
        "input": {
          "memory_base_path": "${params.memory_base_path}",
          "start_date": "${params.start_date}",
          "end_date": "${params.end_date}"
        },
        "position": { "x": 200, "y": 100 }
      },
      {
        "id": "extract_tasks",
        "type": "unit",
        "unit": "task-extractor",
        "input": {
          "contents": "${steps.index_memory.output.contents}",
          "mode": "reflection"
        },
        "position": { "x": 400, "y": 100 }
      },
      {
        "id": "find_patterns",
        "type": "unit",
        "unit": "pattern-finder",
        "input": {
          "extracted_tasks": "${steps.extract_tasks.output}",
          "mode": "reflection"
        },
        "position": { "x": 600, "y": 100 }
      },
      {
        "id": "write_report",
        "type": "unit",
        "unit": "report-writer",
        "input": {
          "extracted_tasks": "${steps.extract_tasks.output}",
          "pattern_analysis": "${steps.find_patterns.output}",
          "mode": "reflection",
          "date": "${steps.index_memory.output.date_range.end}"
        },
        "position": { "x": 800, "y": 100 }
      },
      {
        "id": "done",
        "type": "return",
        "values": {
          "report": "${steps.write_report.output.report}",
          "patterns": "${steps.find_patterns.output.repeating_patterns}",
          "abstractable": "${steps.find_patterns.output.abstractable_modules}",
          "date_range": "${steps.index_memory.output.date_range}"
        },
        "position": { "x": 1000, "y": 100 }
      }
    ],
    "edges": [
      { "source": "start", "target": "index_memory" },
      { "source": "index_memory", "target": "extract_tasks" },
      { "source": "extract_tasks", "target": "find_patterns" },
      { "source": "find_patterns", "target": "write_report" },
      { "source": "write_report", "target": "done" }
    ]
  }
}
