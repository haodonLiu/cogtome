#!/bin/bash
# Reads JSON from stdin, appends to ~/.cogtome/traces/<skill>/<date>.jsonl
# Auto-creates directories. One line per execution.
set -e

TRACE_DIR="${COGTOME_TRACE_DIR:-$HOME/.cogtome/traces}"
INPUT=$(cat)

# Parse skill and date from input JSON using sed
SKILL=$(echo "$INPUT" | sed -n 's/.*"skill"\s*:\s*"\([^"]*\)".*/\1/p')
DATE=$(echo "$INPUT" | sed -n 's/.*"date"\s*:\s*"\([^"]*\)".*/\1/p')

# Fallback: extract from nested trace object
if [ -z "$SKILL" ]; then
  SKILL=$(echo "$INPUT" | sed -n 's/.*"trace"\s*:.*"skill"\s*:\s*"\([^"]*\)".*/\1/p')
fi
if [ -z "$DATE" ]; then
  DATE=$(echo "$INPUT" | sed -n 's/.*"trace"\s*:.*"date"\s*:\s*"\([^"]*\)".*/\1/p')
fi

# Use current date if not found
if [ -z "$DATE" ]; then
  DATE=$(date +%Y-%m-%d)
fi
if [ -z "$SKILL" ]; then
  SKILL="unknown"
fi

# Ensure directory exists
mkdir -p "$TRACE_DIR/$SKILL"

# Append JSON line
echo "$INPUT" >> "$TRACE_DIR/$SKILL/${DATE}.jsonl"
echo "{\"stored\": true, \"file\": \"$TRACE_DIR/$SKILL/${DATE}.jsonl\"}"
